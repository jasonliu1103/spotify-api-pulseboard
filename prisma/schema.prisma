generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SpotifyTimeRange {
  SHORT_TERM
  MEDIUM_TERM
  LONG_TERM
}

enum SyncRunStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

enum AiPlaylistRequestStatus {
  PENDING
  RUNNING
  SUCCEEDED
  FAILED
}

model User {
  id                 String                  @id @default(cuid())
  email              String?                 @unique
  displayName        String?
  avatarUrl          String?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  spotifyAccount     SpotifyAccount?
  playlists          Playlist[]
  topArtistSnapshots UserTopArtistSnapshot[]
  topTrackSnapshots  UserTopTrackSnapshot[]
  savedTracks          SavedTrack[]
  syncRuns             SyncRun[]
  aiPlaylistRequests   AiPlaylistRequest[]
  recentlyPlayedEvents RecentlyPlayedEvent[]
}

model SpotifyAccount {
  id             String   @id @default(cuid())
  userId         String   @unique
  spotifyUserId  String   @unique
  accessToken    String
  refreshToken   String
  tokenExpiresAt DateTime
  country        String?
  product        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Artist {
  id                 String                  @id @default(cuid())
  spotifyArtistId    String                  @unique
  name               String
  genres             String[]
  imageUrl           String?
  popularity         Int?
  createdAt          DateTime                @default(now())
  updatedAt          DateTime                @updatedAt
  trackArtists       TrackArtist[]
  topArtistSnapshots UserTopArtistSnapshot[]
}

model Album {
  id             String   @id @default(cuid())
  spotifyAlbumId String   @unique
  name           String
  releaseDate    String?
  imageUrl       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tracks         Track[]
}

model Track {
  id                     String                  @id @default(cuid())
  spotifyTrackId         String                  @unique
  albumId                String?
  name                   String
  durationMs             Int
  previewUrl             String?
  explicit               Boolean                 @default(false)
  popularity             Int?
  createdAt              DateTime                @default(now())
  updatedAt              DateTime                @updatedAt
  album                  Album?                  @relation(fields: [albumId], references: [id], onDelete: SetNull)
  artists                TrackArtist[]
  topTrackSnapshots      UserTopTrackSnapshot[]
  savedTracks            SavedTrack[]
  playlistTrackSnapshots PlaylistTrackSnapshot[]
  recentlyPlayedEvents   RecentlyPlayedEvent[]
}

model TrackArtist {
  trackId  String
  artistId String
  position Int
  track    Track  @relation(fields: [trackId], references: [id], onDelete: Cascade)
  artist   Artist @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@id([trackId, artistId])
  @@unique([trackId, position])
}

model UserTopArtistSnapshot {
  id         String           @id @default(cuid())
  userId     String
  artistId   String
  timeRange  SpotifyTimeRange
  rank       Int
  snapshotAt DateTime
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  artist     Artist           @relation(fields: [artistId], references: [id], onDelete: Cascade)

  @@unique([userId, artistId, timeRange, snapshotAt])
  @@unique([userId, timeRange, snapshotAt, rank])
  @@index([userId, timeRange, snapshotAt])
}

model UserTopTrackSnapshot {
  id         String           @id @default(cuid())
  userId     String
  trackId    String
  timeRange  SpotifyTimeRange
  rank       Int
  snapshotAt DateTime
  user       User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  track      Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId, timeRange, snapshotAt])
  @@unique([userId, timeRange, snapshotAt, rank])
  @@index([userId, timeRange, snapshotAt])
}

model Playlist {
  id                String             @id @default(cuid())
  userId            String
  spotifyPlaylistId String             @unique
  name              String
  description       String?
  isPublic          Boolean?
  trackCount        Int                @default(0)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  snapshots         PlaylistSnapshot[]

  @@index([userId, updatedAt])
}

model PlaylistSnapshot {
  id          String                  @id @default(cuid())
  playlistId  String
  snapshotAt  DateTime
  name        String
  description String?
  isPublic    Boolean?
  trackCount  Int
  playlist    Playlist                @relation(fields: [playlistId], references: [id], onDelete: Cascade)
  tracks      PlaylistTrackSnapshot[]

  @@unique([playlistId, snapshotAt])
  @@index([playlistId, snapshotAt])
}

model PlaylistTrackSnapshot {
  id                 String           @id @default(cuid())
  playlistSnapshotId String
  trackId            String
  position           Int
  addedAt            DateTime?
  playlistSnapshot   PlaylistSnapshot @relation(fields: [playlistSnapshotId], references: [id], onDelete: Cascade)
  track              Track            @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([playlistSnapshotId, position])
  @@unique([playlistSnapshotId, trackId, position])
}

model SavedTrack {
  id      String   @id @default(cuid())
  userId  String
  trackId String
  savedAt DateTime
  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track   Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, trackId])
  @@index([userId, savedAt])
}

model RecentlyPlayedEvent {
  id          String   @id @default(cuid())
  userId      String
  trackId     String
  playedAt    DateTime
  contextType String?
  contextUri  String?
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  track       Track    @relation(fields: [trackId], references: [id], onDelete: Cascade)

  @@unique([userId, playedAt, trackId])
  @@index([userId, playedAt])
}

model SyncRun {
  id             String        @id @default(cuid())
  userId         String?
  jobName        String
  status         SyncRunStatus @default(PENDING)
  startedAt      DateTime      @default(now())
  finishedAt     DateTime?
  recordsWritten Int           @default(0)
  stepCounts     Json?
  errorMessage   String?
  user           User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([jobName, status, startedAt])
  @@index([userId, startedAt])
}

model AiPlaylistRequest {
  id          String                  @id @default(cuid())
  userId      String
  prompt      String
  status      AiPlaylistRequestStatus @default(PENDING)
  model       String?
  createdAt   DateTime                @default(now())
  updatedAt   DateTime                @updatedAt
  completedAt DateTime?
  user        User                    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
}
